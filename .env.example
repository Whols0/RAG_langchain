APP_NAME=langchain-production-rag
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_TEMPERATURE=0

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
PGVECTOR_COLLECTION=knowledge_base
EMBEDDING_DIMENSION=3072

REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=600
ENABLE_CACHE=true

CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_K=6
RETRIEVAL_FETCH_K=24
MAX_CONTEXT_DOCS=6

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=production-rag
